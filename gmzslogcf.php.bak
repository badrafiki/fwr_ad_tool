function mklink($n){
	global $page;
	$tag = $n == $page?"<b>$n</b>":"$n";
	return "<a href=\"javascript:if(chkfrm(1))postform(document.form1, 'gmzslogcf.php?a=f&p={$n}')\">$tag</a>";
}

if($lastpage > 0)
{
	$s1 = -10;
	$s2 = 10;

	$html_page = "Page: ";

	if($page + $s1 > 1) $html_page .= mklink(1) . "... ";
	for($n = $s1; $n < $s2; $n++)
	{
		$pp = $page + $n;
		if($pp > $lastpage) break;
		if($pp > 0 )
			$html_page .= mklink($pp) . " ";
	}
	if($page + $s2 < $lastpage) $html_page .= " ..." . mklink($lastpage);

	echo $html_page;
}
?>
</form>
